{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@app/core": [
        "libs/core/src"
      ],
      "@app/core/*": [
        "libs/core/src/*"
      ],
      "@app/web": [
        "libs/web/src"
      ],
      "@app/web/*": [
        "libs/web/src/*"
      ],
      "@app/security": [
        "libs/security/src"
      ],
      "@app/security/*": [
        "libs/security/src/*"
      ],
      "@app/validation": [
        "libs/validation/src"
      ],
      "@app/validation/*": [
        "libs/validation/src/*"
      ],
      "@app/kafka": [
        "libs/kafka/src"
      ],
      "@app/kafka/*": [
        "libs/kafka/src/*"
      ],
      "@app/graphql": [
        "libs/graphql/src"
      ],
      "@app/graphql/*": [
        "libs/graphql/src/*"
      ],
      "@app/grpc": [
        "libs/grpc/src"
      ],
      "@app/grpc/*": [
        "libs/grpc/src/*"
      ],
      "@app/redis": [
        "libs/redis/src"
      ],
      "@app/redis/*": [
        "libs/redis/src/*"
      ],
      "@app/contract": [
        "libs/contract/src"
      ],
      "@app/contract/*": [
        "libs/contract/src/*"
      ],
      "@app/audit": [
        "libs/audit/src"
      ],
      "@app/audit/*": [
        "libs/audit/src/*"
      ],
      "@app/observability": [
        "libs/observability/src"
      ],
      "@app/observability/*": [
        "libs/observability/src/*"
      ],
      "@app/idempotency": [
        "libs/idempotency/src"
      ],
      "@app/idempotency/*": [
        "libs/idempotency/src/*"
      ],
      "@app/lock": [
        "libs/lock/src"
      ],
      "@app/lock/*": [
        "libs/lock/src/*"
      ]
    }
  }
}
