        {
          "host": ["http://account-service:8080"],
          "url_pattern": "/api/accounts/{path}",
          "encoding": "json",
          "method": "DELETE"
        }
      ]
    },
    {
      "endpoint": "/api/accounts/{path}",
      "method": "POST",
      "backend": [
        {
          "host": ["http://account-service:8080"],
          "url_pattern": "/api/accounts/{path}",
          "encoding": "json",
          "method": "POST"
        }
      ]
    },
    {
      "endpoint": "/api/v1/notifications/stream",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "host": ["http://notification-service:8080"],
          "url_pattern": "/api/v1/notifications/stream",
          "encoding": "no-op",
          "method": "GET"
