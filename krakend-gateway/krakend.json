{
  "version": 3,
  "name": "Microservice API Gateway",
  "port": 8080,
  "timeout": "3s",
  "cache_ttl": "300s",
  "output_encoding": "json",
  "endpoints": [
    {
      "endpoint": "/api/v1/commands",
      "method": "GET",
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/actuator/health",
          "encoding": "json",
          "sd": "static",
          "method": "GET",
          "host": [
            "http://generic-command-service:8080"
          ],
          "disable_host_sanitize": false
        }
      ]
    },
    {
      "endpoint": "/api/v1/orders",
      "method": "GET",
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/orders",
          "encoding": "json",
          "sd": "static",
          "method": "GET",
          "host": [
            "http://quarkus-template-service:8080"
          ],
          "disable_host_sanitize": false
        }
      ]
    },
    {
      "endpoint": "/api/v1/node",
      "method": "GET",
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/",
          "encoding": "json",
          "sd": "static",
          "method": "GET",
          "host": [
            "http://node-project-template:3000"
          ],
          "disable_host_sanitize": false
        }
      ]
    }
  ]
}
