{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/project-template/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/project-template/tsconfig.app.json",
    "assets": [
      {
        "include": "**/*.proto",
        "outDir": "dist",
        "watchAssets": true
      }
    ]
  },
  "monorepo": true,
  "root": "apps/project-template",
  "projects": {
    "alert": {
      "type": "application",
      "root": "apps/alert",
      "entryFile": "main",
      "sourceRoot": "apps/alert/src",
      "compilerOptions": {
        "tsConfigPath": "apps/alert/tsconfig.app.json"
      }
    },
    "market-data": {
      "type": "application",
      "root": "apps/market-data",
      "entryFile": "main",
      "sourceRoot": "apps/market-data/src",
      "compilerOptions": {
        "tsConfigPath": "apps/market-data/tsconfig.app.json"
      }
    },
    "notification": {
