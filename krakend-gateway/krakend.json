{
  "version": 3,
  "name": "Microservice API Gateway",
  "port": 8080,
  "timeout": "10s",
  "cache_ttl": "0s",
  "output_encoding": "json",
  "extra_config": {
    "router": {
      "return_error_msg": true
    }
  },
  "endpoints": [
    {
      "endpoint": "/api/auth/{path}",
      "method": "POST",
      "backend": [
        {
          "host": ["http://auth-service:8080"],
          "url_pattern": "/api/auth/{path}",
          "encoding": "json",
          "method": "POST"
        }
      ]
    },
    {
      "endpoint": "/api/v1/auth/{path}",
      "method": "POST",
      "backend": [
        {
          "host": ["http://auth-service:8080"],
          "url_pattern": "/api/v1/auth/{path}",
          "encoding": "json",
          "method": "POST"
        }
      ]
    },
    {
      "endpoint": "/api/accounts",
      "method": "POST",
      "backend": [
        {
          "host": ["http://account-service:8080"],
          "url_pattern": "/api/accounts",
          "encoding": "json",
          "method": "POST"
        }
      ]
    },
    {
      "endpoint": "/api/accounts",
      "method": "GET",
      "backend": [
        {
          "host": ["http://account-service:8080"],
          "url_pattern": "/api/accounts",
          "encoding": "json",
          "method": "GET"
        }
      ]
    },
    {
      "endpoint": "/api/accounts/{path}",
      "method": "GET",
      "backend": [
        {
          "host": ["http://account-service:8080"],
          "url_pattern": "/api/accounts/{path}",
          "encoding": "json",
          "method": "GET"
        }
      ]
    },
    {
